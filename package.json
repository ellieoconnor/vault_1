{
    "name": "vault-1",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "build": "npm run build --workspace=apps/frontend",
        "test": "echo \"Error: no test specified\" && exit 1",
        "test:e2e": "playwright test",
        "test:pact:consumer": "vitest run --config vitest.config.pact.ts",
        "publish:pact": ". ./scripts/env-setup.sh && ./scripts/publish-pact.sh",
        "can:i:deploy:consumer": ". ./scripts/env-setup.sh && PACTICIPANT=vault-1-frontend ./scripts/can-i-deploy.sh",
        "record:consumer:deployment": ". ./scripts/env-setup.sh && PACTICIPANT=vault-1-frontend ./scripts/record-deployment.sh"
    },
    "workspaces": [
        "apps/*"
    ],
